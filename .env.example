# Core
LLM_PROVIDER=nvidia
OPENAI_API_KEY=
NVIDIA_API_KEY=
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL=openai/gpt-oss-120b
DATABASE_PATH=.data/ai_news_agent.sqlite3
LOG_LEVEL=INFO

# News collection
NEWS_LOOKBACK_HOURS=36
NEWS_MAX_CANDIDATES=30
POST_ARTICLE_COUNT=1
NEWS_QUERY=artificial intelligence OR AI OR OpenAI OR Anthropic OR Google DeepMind OR Meta AI
RSS_FEEDS=https://www.theverge.com/ai-artificial-intelligence/rss/index.xml,https://techcrunch.com/category/artificial-intelligence/feed/,https://www.technologyreview.com/topic/artificial-intelligence/feed/
TAVILY_API_KEY=
NEWSAPI_KEY=

# Telegram approval
TELEGRAM_BOT_TOKEN=
TELEGRAM_APPROVER_CHAT_ID=
TELEGRAM_APPROVAL_TIMEOUT_MINUTES=2
TELEGRAM_AUTO_APPROVE_ON_TIMEOUT=true

# Optional Facebook publishing after approval
FACEBOOK_ENABLED=false
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# Automation
RUN_MODE=once
SCHEDULE_CRON=0 8 * * *
UI_THEME_MODE=light
UI_THEME_COLOR=#1264a3
